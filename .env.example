# PassiAgent Configuration Template
# Copy to .env and fill in your API keys:
#   cp .env.example .env

# ── Default LLM Provider ────────────────────────────
# Options: anthropic, openai, ollama
PASSI_DEFAULT_PROVIDER=anthropic

# ── Anthropic (DeepSeek Anthropic-compatible endpoint) ──
PASSI_ANTHROPIC__API_KEY=sk-your-deepseek-api-key
PASSI_ANTHROPIC__BASE_URL=https://api.deepseek.com/anthropic
PASSI_ANTHROPIC__MODEL=deepseek-v4-pro
# Other model options: deepseek-v4-flash
PASSI_ANTHROPIC__MAX_TOKENS=8192
PASSI_ANTHROPIC__TEMPERATURE=0.0

# ── OpenAI (DeepSeek OpenAI-compatible endpoint) ──
PASSI_OPENAI__API_KEY=sk-your-deepseek-api-key
PASSI_OPENAI__BASE_URL=https://api.deepseek.com
PASSI_OPENAI__MODEL=deepseek-v4-pro
# Other model options: deepseek-v4-flash, deepseek-chat
PASSI_OPENAI__MAX_TOKENS=4096
PASSI_OPENAI__TEMPERATURE=0.0

# ── Ollama (local) ──────────────────────────────────
# PASSI_OLLAMA__BASE_URL=http://localhost:11434/v1
# PASSI_OLLAMA__MODEL=llama3.1
# PASSI_OLLAMA__ENABLED=true

# ── R Environment ───────────────────────────────────
# R home is auto-detected. Set explicitly if needed:
# PASSI_EXECUTION__R_HOME=
# PASSI_EXECUTION__R_PATH=Rscript
# PASSI_EXECUTION__RPY2_ENABLED=true

# ── Execution ───────────────────────────────────────
# PASSI_EXECUTION__PYTHON_PATH=python
# PASSI_EXECUTION__TIMEOUT_SECONDS=300

# ── Session ─────────────────────────────────────────
# PASSI_SESSION__SESSIONS_DIR=./.passi/sessions

# ── Debug ───────────────────────────────────────────
# PASSI_DEBUG=true
