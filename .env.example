# HarnessAgent Configuration Template
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── LLM Provider ──────────────────────────────────────
# Choose: anthropic, openai, ollama
HARNESS_DEFAULT_PROVIDER=anthropic

# Anthropic (Claude)
HARNESS_ANTHROPIC__API_KEY=
HARNESS_ANTHROPIC__MODEL=claude-sonnet-4-6

# OpenAI
HARNESS_OPENAI__API_KEY=
HARNESS_OPENAI__MODEL=gpt-4o

# Ollama (local)
# HARNESS_OLLAMA__BASE_URL=http://localhost:11434/v1
# HARNESS_OLLAMA__MODEL=llama3.1
# HARNESS_OLLAMA__ENABLED=true

# ── R Environment (rpy2 + Bioconductor) ───────────────
# R home is auto-detected in this order:
#   1) HARNESS_EXECUTION__R_HOME (below)
#   2) R_HOME / HARNESS_R_HOME env vars
#   3) ./R/  (project-local, recommended)
#   4) C:\Program Files\R\R-x.x.x (system, newest first)
#
# To use project-local R, leave blank — it auto-detects ./R/
HARNESS_EXECUTION__R_HOME=

# R library path for user-installed packages (auto-creates ./R-lib/)
# HARNESS_EXECUTION__R_LIB_PATH=

# Rscript path (auto-detected from R_HOME)
HARNESS_EXECUTION__R_PATH=Rscript

# Enable rpy2 bridge
HARNESS_EXECUTION__RPY2_ENABLED=true

# ── Execution ─────────────────────────────────────────
# HARNESS_EXECUTION__PYTHON_PATH=python
# HARNESS_EXECUTION__TIMEOUT_SECONDS=300
# HARNESS_EXECUTION__CONDA_ENV=bioinfo

# ── Session ───────────────────────────────────────────
# HARNESS_SESSION__SESSIONS_DIR=./sessions

# ── General ───────────────────────────────────────────
# HARNESS_DEBUG=true
# HARNESS_DATA_DIR=./data
# HARNESS_OUTPUT_DIR=./output
